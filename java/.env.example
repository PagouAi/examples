# Pagou API v2 — example configuration. Placeholders only; never commit a real .env.
# Sandbox is the default. Sandbox and production tokens are separate.

PAGOU_ENVIRONMENT=sandbox
PAGOU_BASE_URL=https://api.sandbox.pagou.ai

# Server-side secret API token. Never exposed to the browser.
PAGOU_API_TOKEN=your_sandbox_token_here

# Client-side publishable key for the Payment Element (pk_test_* in sandbox).
# Safe to ship to the browser; used only by the card-element demo.
PAGOU_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# HTTPS endpoint that receives Pagou webhooks.
PAGOU_WEBHOOK_URL=https://your-app.example/webhooks/pagou

# Optional client tuning (defaults shown).
PAGOU_TIMEOUT_MS=30000
PAGOU_MAX_RETRIES=2

# Optional: reuse an existing customer id in the subscriptions example.
# PAGOU_CUSTOMER_ID=

# Optional: a pgct_ card token from the Payment Element, for the card and
# subscription examples that run from the CLI.
# PAGOU_CARD_TOKEN=pgct_...
